# ─────────────────────────────────────────────
# API endpoint
# ─────────────────────────────────────────────
API_BASE_URL=https://api.openai.com/v1

# ─────────────────────────────────────────────
# Authentication — choose ONE mode
# ─────────────────────────────────────────────

# AUTH_MODE options:
#   apikey   — static API key sent as Bearer token (default)
#   oauth    — fetch token via client credentials grant before each request

AUTH_MODE=apikey

# For AUTH_MODE=apikey:
API_KEY=your-api-key-here

# For AUTH_MODE=oauth:
TOKEN_URL=https://your-auth-server.com/oauth/token
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
# Optional: space-separated scopes (leave blank if not required)
TOKEN_SCOPE=

# How to send the token to the API
# TOKEN_HEADER_NAME: the header to use (default: Authorization)
# TOKEN_PREFIX: the prefix before the token value (default: Bearer)
# Examples:
#   Standard JWT:        TOKEN_HEADER_NAME=Authorization   TOKEN_PREFIX=Bearer
#   Axway API Gateway:   TOKEN_HEADER_NAME=Authorization   TOKEN_PREFIX=Bearer
#   Custom header:       TOKEN_HEADER_NAME=x-api-key       TOKEN_PREFIX=
TOKEN_HEADER_NAME=Authorization
TOKEN_PREFIX=Bearer

# Set to true to log the full token response and token preview on each fetch
# Useful for debugging 401 errors — turn off in production
TOKEN_DEBUG=false

# ─────────────────────────────────────────────
# System prompt
# ─────────────────────────────────────────────
SYSTEM_PROMPT=You are a helpful assistant.

# ─────────────────────────────────────────────
# UI customization
# ─────────────────────────────────────────────
CHATBOT_TITLE=AI Assistant
CHATBOT_SUBTITLE=How can I help you today?
PRIMARY_COLOR=#0066cc
SECONDARY_COLOR=#0052a3

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
